# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# EIA (Energy Information Administration) API - for live WTI oil price feed
# Free key at: https://www.eia.gov/opendata/register.php
# Leave empty to disable the WTI price card on the dashboard
EIA_API_KEY=

# Database Configuration
DATABASE_PATH=./database/qa_demo.db

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# Chat history depth (number of prior messages sent to Claude for context)
CONVERSATION_HISTORY_LIMIT=10

# Deal Configuration
DEAL_NAME=Huntington Oil & Gas II
DEAL_ID=1

# Auth (REQUIRED in production)
JWT_SECRET=change-this-to-a-random-32-char-string

# Email (SMTP) - Leave empty for dev mode (magic links logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
